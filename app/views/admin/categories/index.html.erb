<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-xl);">
  <h1>Categories</h1>
  <%= link_to 'New Category', new_admin_category_path, class: "btn btn-primary" %>
</div>

<div class="card" style="padding: 0;">
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr style="border-bottom: 3px solid var(--border-color); background: #f8f9fa;">
        <th style="padding: 1rem; text-align: left; border-right: 3px solid var(--border-color);">Name</th>
        <th style="padding: 1rem; text-align: left; border-right: 3px solid var(--border-color);">Description</th>
        <th style="padding: 1rem; text-align: left; width: 150px;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |category| %>
        <tr style="border-bottom: 3px solid var(--border-color);">
          <td style="padding: 1rem; border-right: 3px solid var(--border-color); font-weight: bold;"><%= category.name %></td>
          <td style="padding: 1rem; border-right: 3px solid var(--border-color);"><%= truncate(category.description, length: 100) %></td>
          <td style="padding: 1rem; display: flex; gap: 0.5rem;">
            <%= link_to 'Edit', edit_admin_category_path(category), class: "btn btn-secondary btn-sm" %>
            <%= button_to 'Delete', admin_category_path(category), method: :delete, form: { data: { turbo_confirm: 'Are you sure?' } }, class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @categories.empty? %>
    <div style="padding: 2rem; text-align: center; color: var(--text-muted);">
      No categories found. Let's create some!
    </div>
  <% end %>
</div>
