<div style="margin-bottom: var(--space-xl);">
  <%= link_to '← Back to Catalog', courses_path, class: "btn btn-ghost btn-sm", style: "margin-bottom: 1rem;" %>
  <h1 style="margin-bottom: 0.5rem; font-size: 2.5rem;"><%= @course.title %></h1>
  <div style="display: flex; gap: 0.5rem; align-items: center; margin-top: 1.5rem;">
    <span class="badge"><%= @course.category.name rescue "N/A" %></span>
    <span class="badge" style="background: var(--dark); color: white;"><%= @course.difficulty&.capitalize %></span>
  </div>
</div>

<div class="card" style="margin-bottom: var(--space-xl); padding: 2rem;">
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 3px solid var(--border-color);">
    <div style="width: 50px; height: 50px; background: var(--gradient-instr); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-weight: bold; border: 3px solid var(--dark);">
      <%= @course.instructor.name.first.upcase rescue "I" %>
    </div>
    <div>
      <div style="font-weight: bold; font-size: 1.1rem;"><%= @course.instructor.name rescue "Unknown Instructor" %></div>
      <div style="color: var(--text-muted); font-size: 0.9rem;">Course Instructor</div>
    </div>
  </div>

  <h2>About this Course</h2>
  <p style="white-space: pre-line; margin-top: var(--space-md); font-size: 1.1rem; line-height: 1.6;"><%= @course.description %></p>
</div>

<div style="text-align: center;">
  <a href="#" class="btn btn-primary" style="font-size: 1.25rem; padding: 1rem 2rem;">Enroll in Course (Coming Soon)</a>
</div>
