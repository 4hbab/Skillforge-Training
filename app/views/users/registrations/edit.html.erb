<div class="card" style="max-width: 600px; margin: var(--space-xl) auto;">
  <div class="card-header">
    <h2 class="page-title" style="margin-bottom: 0;">Edit Profile</h2>
  </div>

  <div class="card-body">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "users/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :avatar, "Profile Picture", class: "form-label" %>
        <% if resource.avatar.attached? %>
          <div style="margin-bottom: var(--space-sm);">
            <%= image_tag resource.avatar, style: "border-radius: 50%; object-fit: cover; width: 64px; height: 64px; border: var(--border-width) solid var(--border-color);" %>
          </div>
        <% end %>
        <%= f.file_field :avatar, accept: 'image/png, image/jpeg', direct_upload: true, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="flash flash-info">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
      <% end %>

      <div class="form-group">
        <%= f.label :password, class: "form-label" %>
        <span class="form-hint" style="display: block; margin-bottom: var(--space-xs);">(leave blank if you don't want to change it)</span>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-input" %>
        <% if @minimum_password_length %>
          <span class="form-hint"><%= @minimum_password_length %> characters minimum</span>
        <% end %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :current_password, class: "form-label" %>
        <span class="form-hint" style="display: block; margin-bottom: var(--space-xs);">(we need your current password to confirm your changes)</span>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-input" %>
      </div>

      <div class="form-actions" style="margin-top: var(--space-lg);">
        <%= f.submit "Update Profile", class: "btn btn-primary" %>
        <%= link_to "Cancel", :back, class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>

  <div class="card-footer" style="padding-top: var(--space-md); border-top: var(--border-width) dashed var(--border-color); margin-top: var(--space-xl);">
    <h3 style="font-size: var(--text-lg); margin-bottom: var(--space-sm);">Danger Zone</h3>
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <p style="margin: 0; color: var(--text-muted);">Unhappy with your account? This action cannot be undone.</p>
      <%= button_to "Cancel my account", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn btn-danger" %>
    </div>
  </div>
</div>
