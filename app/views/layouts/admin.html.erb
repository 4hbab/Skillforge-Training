<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for?(:title) ? "#{yield(:title)} — Admin" : "Admin Panel" %> | SkillForge</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <div class="dashboard-shell">
      <!-- ── Sidebar ───────────────────────────────────────────────────────── -->
      <aside class="sidebar">
        <div class="sidebar-logo">
          <h2>⚡ SkillForge</h2>
          <div class="role-tag">Admin Console</div>
        </div>

        <nav class="sidebar-nav">
          <div class="sidebar-section-label">Overview</div>
          <%= link_to admin_dashboard_index_path, class: "#{active_nav(admin_dashboard_index_path)}" do %>
            <span class="nav-icon">🏠</span> Dashboard
          <% end %>

          <div class="sidebar-section-label">Management</div>
          <%= link_to admin_courses_path, class: "#{active_nav(admin_courses_path)}" do %>
            <span class="nav-icon">📚</span> Courses
          <% end %>
          <%= link_to admin_categories_path, class: "#{active_nav(admin_categories_path)}" do %>
            <span class="nav-icon">🏷️</span> Categories
          <% end %>
          <a href="#" style="opacity:0.4;cursor:not-allowed"><span class="nav-icon">👥</span> Users <span style="font-size:0.65rem;margin-left:auto;color:var(--text-muted)">Phase 3</span></a>

          <div class="sidebar-section-label">Reports</div>
          <a href="#" style="opacity:0.4;cursor:not-allowed"><span class="nav-icon">📊</span> Analytics <span style="font-size:0.65rem;margin-left:auto;color:var(--text-muted)">Phase 3</span></a>
          <a href="#" style="opacity:0.4;cursor:not-allowed"><span class="nav-icon">🎓</span> Certificates <span style="font-size:0.65rem;margin-left:auto;color:var(--text-muted)">Phase 5</span></a>
        </nav>

        <div class="sidebar-footer">
          <%= link_to edit_user_registration_path, class: "sidebar-user", style: "text-decoration: none; color: inherit; display: flex; transition: transform 0.2s; cursor: pointer;" do %>
            <div class="sidebar-avatar" style="padding: 0;">
              <% if current_user.respond_to?(:avatar) && current_user.avatar.attached? %>
                <%= image_tag current_user.avatar, style: "width: 100%; height: 100%; object-fit: cover; border-radius: inherit;" %>
              <% else %>
                <%= current_user.name.first.upcase rescue "U" %>
              <% end %>
            </div>
            <div class="sidebar-user-info">
              <div class="name" style="text-decoration: underline; text-decoration-color: transparent; transition: text-decoration-color 0.2s;"><%= current_user.display_name %></div>
              <div class="email"><span class="badge badge-admin">Admin</span></div>
            </div>
          <% end %>
          <div style="margin-top: var(--space-md);">
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-ghost btn-sm", style: "width:100%;justify-content:center;" %>
          </div>
        </div>
      </aside>

      <!-- ── Main Content ───────────────────────────────────────────────────── -->
      <main class="main-content">
        <%= render "shared/flash" %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
